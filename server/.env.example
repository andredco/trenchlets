# =========================================================
# Trenchlets server · environment variables
# =========================================================
# Copy these into Railway's Variables tab. Never commit real
# values to git.

# Postgres connection — Railway provides this automatically when
# you link a Postgres plugin to the service.
DATABASE_URL=postgres://user:pass@host:5432/db

# Solana RPC. Use a Helius or Triton key for sustained load.
# The free public endpoint works for testing but is rate limited.
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# $TRENCHLETS token mint address. Empty until launch — server
# treats every wallet as SHRIMP tier when this is unset.
TRENCHLETS_MINT=

# Comma-separated list of token mints to track for live prices
# (DexScreener). Set to your 10 launch token mints + $TRENCHLETS once live.
TRACK_MINTS=

# Salt used to hash IPs server-side. Rotate periodically. Any random string.
IP_SALT=change-me-to-a-long-random-string

# Optional: port. Railway injects PORT automatically.
PORT=3000

# Admin dashboard token. Required to access /admin and /admin/api/*.
# Generate any random string (32+ chars). Keep this secret.
ADMIN_TOKEN=

# Vault keypair as a JSON array of 64 bytes (output of `solana-keygen new`).
# ONLY needed for the epoch settlement script (`npm run settle -- --execute`).
# DO NOT set this in the main service env — keep it on a separate machine
# where you run `npm run settle` manually. Railway injecting this would mean
# the running web server has signing power, which we don't want.
VAULT_KEYPAIR=
