# =========================================================
# Settler service env vars (Railway)
# =========================================================
# This service runs by itself with NO public surface. Only it has
# access to VAULT_KEYPAIR. Web service shouldn't see this var.

# Shared Postgres — same DB the web service uses.
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Solana RPC. Use Helius / Triton / your own. Free public works for testing.
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Vault keypair. Two formats accepted:
#   1. Base58 string  (what Phantom exports → Settings → Show Private Key)
#   2. JSON byte array  (output of `solana-keygen new`)
# Either one works — paste whichever you have. This is THE most sensitive
# variable in the whole system. Do not log, share, or commit.
VAULT_KEYPAIR=

# Run with DRY_RUN=true for the first few cycles so you can review the
# proposed swaps + payouts before signing on-chain. Flip to false (or
# remove the var) when you're confident.
DRY_RUN=true

# Tunable economics (defaults are 40% release cap, 30% protocol take).
# Leave unset to use the locked-in values.
# RELEASE_CAP_PCT=0.40
# PROTOCOL_TAKE_PCT=0.30
# SLIPPAGE_BPS=500
